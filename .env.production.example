# rinpanel — production environment template.
# Copy to .env.local on the VPS and fill in the values.
# See DEPLOY.md for full setup.

# Long random secret used to sign JWT session tokens.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Production: run shell commands directly on the host (not via docker exec).
# This is what flips the lib/shell.ts seam to host-mode.
USE_DOCKER=false

# Admin login. Used by `npm run db:seed` to bootstrap the single admin user.
# Change ADMIN_PASSWORD AFTER seeding (re-run db:seed with the new value).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional — where the SQLite database lives. Default is ./panel.db (cwd).
# Set to an absolute path if you want it outside the install directory.
# DATABASE_PATH=/opt/rinpanel/panel.db

# Slice S (SSL).
LETS_ENCRYPT_EMAIL=
# Production: false = issue real certs against Let's Encrypt prod.
CERTBOT_DRY_RUN=false
