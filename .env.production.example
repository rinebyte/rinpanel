# rinpanel — production environment template.
# Copy to .env.local on the VPS and fill in the values.
# See DEPLOY.md for full setup.

# Long random secret used to sign JWT session tokens.
# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Required when accessing the panel via IP (or any host that isn't a registered
# canonical domain). NextAuth v5 refuses to issue session cookies in production
# unless this is true OR you set AUTH_URL to your real https://panel.<domain>.
# Quick mode (IP:PORT) → set true. Production mode behind a known domain → can
# leave true too, or set AUTH_URL instead.
AUTH_TRUST_HOST=true

# Production: run shell commands directly on the host (not via docker exec).
# This is what flips the lib/shell.ts seam to host-mode.
USE_DOCKER=false

# Admin login. Used by `npm run db:seed` to bootstrap the single admin user.
# Change ADMIN_PASSWORD AFTER seeding (re-run db:seed with the new value).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Optional — where the SQLite database lives. Default is ./panel.db (cwd).
# Set to an absolute path if you want it outside the install directory.
# DATABASE_PATH=/opt/rinpanel/panel.db

# Where Next listens. 0.0.0.0 + a non-default port = directly reachable as
# http://<VPS_IP>:8443/login (Quick mode). For the nginx reverse-proxy mode,
# you'd typically set HOSTNAME=127.0.0.1 instead so the panel is only reachable
# through the proxy on :443. See DEPLOY.md for both modes.
HOSTNAME=0.0.0.0
PORT=8443

# Slice S (SSL).
LETS_ENCRYPT_EMAIL=
# Production: false = issue real certs against Let's Encrypt prod.
CERTBOT_DRY_RUN=false
