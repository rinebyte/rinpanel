AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32
USE_DOCKER=true
CONTAINER_NAME=panel-server
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong

# Where Next listens. Defaults: HOSTNAME=0.0.0.0 PORT=3000 (dev convention).
# In prod, set PORT=8443 (or another non-default) so the panel isn't trivially scanned.
# HOSTNAME=0.0.0.0
# PORT=3000

# Slice S (SSL) — set the email used as Let's Encrypt account contact.
LETS_ENCRYPT_EMAIL=
# Dev default: dry-run (no real cert issued).
CERTBOT_DRY_RUN=true
